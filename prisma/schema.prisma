generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ============================================================
// 枚举类型
// ============================================================

enum OrderStatus {
  PENDING
  PAID
  PROCESSING
  COMPLETED
  CANCELLED
}

enum CardStatus {
  AVAILABLE
  LOCKED
  SOLD
  DISABLED
}

enum PaymentChannel {
  BALANCE
  EPUSDT
  OKPAY
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  EXPIRED
}

enum BalanceLogType {
  RECHARGE
  PAY_ORDER
  ADMIN_ADD
  REFUND
}

// ============================================================
// User - Telegram 用户
// ============================================================
model User {
  id        Int      @id @default(autoincrement())
  tgId      BigInt   @unique @map("tg_id")
  username  String?  @db.VarChar(100)
  firstName String?  @db.VarChar(100) @map("first_name")
  lastName  String?  @db.VarChar(100) @map("last_name")
  avatarUrl String?  @db.VarChar(500) @map("avatar_url")
  balance   Decimal  @default(0) @db.Decimal(10, 2)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  orders         Order[]
  recharges      RechargeLog[]
  paymentRecords PaymentRecord[]
  balanceLogs    BalanceLog[]
  deliveryLogs   DeliveryLog[]

  @@map("users")
}

// ============================================================
// Product - 商品
// ============================================================
model Product {
  id          Int      @id @default(autoincrement())
  name        String   @db.VarChar(200)
  description String?  @db.Text
  price       Decimal  @db.Decimal(10, 2)
  stock       Int      @default(0)
  images      String?  @db.Text
  category    String?  @db.VarChar(100)
  sales       Int      @default(0)
  sortOrder   Int      @default(0) @map("sort_order")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  orderItems  OrderItem[]
  specs       ProductSpec[]
  cardSecrets CardSecret[]

  @@map("products")
}

// ============================================================
// ProductSpec - 商品规格（如：月卡/季卡/年卡）
// ============================================================
model ProductSpec {
  id        Int      @id @default(autoincrement())
  productId Int      @map("product_id")
  product   Product  @relation(fields: [productId], references: [id])
  name      String   @db.VarChar(100)
  price     Decimal  @db.Decimal(10, 2)
  stock     Int      @default(0)
  sortOrder Int      @default(0) @map("sort_order")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  cardSecrets CardSecret[]
  orderItems  OrderItem[]

  @@map("product_specs")
}

// ============================================================
// CardSecret - 卡密
// ============================================================
model CardSecret {
  id            Int          @id @default(autoincrement())
  productId     Int          @map("product_id")
  product       Product      @relation(fields: [productId], references: [id])
  specId        Int?         @map("spec_id")
  spec          ProductSpec? @relation(fields: [specId], references: [id])
  content       String       @unique @db.VarChar(500)
  status        CardStatus   @default(AVAILABLE)
  lockedOrderId Int?         @map("locked_order_id")
  soldOrderId   Int?         @map("sold_order_id")
  soldToUserId  Int?         @map("sold_to_user_id")
  lockedAt      DateTime?    @map("locked_at")
  soldAt        DateTime?    @map("sold_at")
  createdAt     DateTime     @default(now()) @map("created_at")

  @@index([productId, specId, status])
  @@index([lockedOrderId])
  @@index([soldOrderId])
  @@map("card_secrets")
}

// ============================================================
// Order - 订单
// ============================================================
model Order {
  id              Int             @id @default(autoincrement())
  orderNo         String          @unique @db.VarChar(32) @map("order_no")
  userId          Int             @map("user_id")
  user            User            @relation(fields: [userId], references: [id])
  status          OrderStatus     @default(PENDING)
  totalAmount     Decimal         @db.Decimal(10, 2) @map("total_amount")
  remark          String?         @db.VarChar(500)
  paymentMethod   PaymentChannel? @map("payment_method")
  payStatus       PaymentStatus   @default(PENDING) @map("pay_status")
  paidAt          DateTime?       @map("paid_at")
  expiresAt       DateTime?       @map("expires_at")
  cancelReason    String?         @db.VarChar(100) @map("cancel_reason")
  externalOrderNo String?         @db.VarChar(100) @map("external_order_no")
  usdtAmount      Decimal?        @db.Decimal(18, 6) @map("usdt_amount")
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")

  items        OrderItem[]
  payments     PaymentRecord[]
  deliveryLogs DeliveryLog[]

  @@map("orders")
}

// ============================================================
// OrderItem - 订单明细
// ============================================================
model OrderItem {
  id        Int          @id @default(autoincrement())
  orderId   Int          @map("order_id")
  order     Order        @relation(fields: [orderId], references: [id])
  productId Int          @map("product_id")
  product   Product      @relation(fields: [productId], references: [id])
  specId    Int?         @map("spec_id")
  spec      ProductSpec? @relation(fields: [specId], references: [id])
  quantity  Int
  price     Decimal      @db.Decimal(10, 2)
  name      String       @db.VarChar(200)
  specName  String?      @db.VarChar(100) @map("spec_name")

  @@map("order_items")
}

// ============================================================
// RechargeLog - 充值记录（管理员手动充值）
// ============================================================
model RechargeLog {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  user      User     @relation(fields: [userId], references: [id])
  amount    Decimal  @db.Decimal(10, 2)
  note      String?  @db.VarChar(200)
  createdAt DateTime @default(now()) @map("created_at")

  @@map("recharge_logs")
}

// ============================================================
// PaymentRecord - 支付流水
// ============================================================
model PaymentRecord {
  id              Int            @id @default(autoincrement())
  orderId         Int?           @map("order_id")
  order           Order?         @relation(fields: [orderId], references: [id])
  userId          Int            @map("user_id")
  user            User           @relation(fields: [userId], references: [id])
  channel         PaymentChannel
  status          PaymentStatus  @default(PENDING)
  amountCny       Decimal        @db.Decimal(10, 2) @map("amount_cny")
  amountUsdt      Decimal?       @db.Decimal(18, 6) @map("amount_usdt")
  externalOrderNo String?        @db.VarChar(100) @map("external_order_no")
  txHash          String?        @db.VarChar(200) @map("tx_hash")
  rawPayload      String?        @db.Text @map("raw_payload")
  paidAt          DateTime?      @map("paid_at")
  createdAt       DateTime       @default(now()) @map("created_at")

  @@index([orderId])
  @@index([userId])
  @@index([channel, status])
  @@index([externalOrderNo])
  @@map("payment_records")
}

// ============================================================
// BalanceLog - 余额流水
// ============================================================
model BalanceLog {
  id            Int            @id @default(autoincrement())
  userId        Int            @map("user_id")
  user          User           @relation(fields: [userId], references: [id])
  type          BalanceLogType
  amount        Decimal        @db.Decimal(10, 2)
  balanceBefore Decimal        @db.Decimal(10, 2) @map("balance_before")
  balanceAfter  Decimal        @db.Decimal(10, 2) @map("balance_after")
  orderId       Int?           @map("order_id")
  note          String?        @db.VarChar(255)
  createdAt     DateTime       @default(now()) @map("created_at")

  @@index([userId])
  @@index([orderId])
  @@map("balance_logs")
}

// ============================================================
// PaymentCallbackLog - 第三方支付回调日志
// ============================================================
model PaymentCallbackLog {
  id              Int            @id @default(autoincrement())
  channel         PaymentChannel
  orderNo         String?        @db.VarChar(100) @map("order_no")
  externalOrderNo String?        @db.VarChar(100) @map("external_order_no")
  payload         String         @db.Text
  signatureValid  Boolean        @default(false) @map("signature_valid")
  processed       Boolean        @default(false)
  message         String?        @db.VarChar(255)
  createdAt       DateTime       @default(now()) @map("created_at")

  @@index([channel])
  @@index([orderNo])
  @@index([externalOrderNo])
  @@map("payment_callback_logs")
}

// ============================================================
// DeliveryLog - 发卡日志
// ============================================================
model DeliveryLog {
  id           Int      @id @default(autoincrement())
  orderId      Int      @map("order_id")
  order        Order    @relation(fields: [orderId], references: [id])
  userId       Int      @map("user_id")
  user         User     @relation(fields: [userId], references: [id])
  cardSecretId Int      @map("card_secret_id")
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([orderId])
  @@index([userId])
  @@index([cardSecretId])
  @@map("delivery_logs")
}

// ============================================================
// AdminConfig - 后台配置（TOTP 密钥）
// ============================================================
model AdminConfig {
  id         Int      @id @default(autoincrement())
  totpSecret String   @db.VarChar(100) @map("totp_secret")
  isSetup    Boolean  @default(false) @map("is_setup")
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("admin_config")
}

// ============================================================
// SystemSetting - 系统配置（KV 存储）
// 支持保存: usdt_rate, order_expire_minutes,
//           epusdt_api_url, epusdt_merchant_id, epusdt_secret,
//           okpay_api_url, okpay_merchant_id, okpay_secret
// ============================================================
model SystemSetting {
  id        Int      @id @default(autoincrement())
  key       String   @unique @db.VarChar(100)
  value     String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("system_settings")
}
